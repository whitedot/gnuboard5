{
  "name": "g5aif",
  "version": "1.0.0",
  "description": "이 프로젝트는 그누보드 5(G5) 및 영카트 기반 시스템의 리팩토링 프로젝트입니다.",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "npm run build:theme && npm run build:theme:site && npm run build:admin",
    "build:theme": "tailwindcss -i ./tailwind4/common.css -o ./css/common.css --minify",
    "build:theme:site": "tailwindcss -i ./tailwind4/theme.css -o ./css/theme.css --minify",
    "build:admin": "tailwindcss -i ./tailwind4/admin.css -o ./adm/css/admin.css --minify",
    "check:admin-refactor": "node ./scripts/check-admin-refactor.js",
    "check:common-query-refactor": "node ./scripts/check-common-query-refactor.js",
    "check:legacy-phpexcel-retirement": "node ./scripts/check-legacy-phpexcel-retirement.js",
    "check:legacy-request-extract-retirement": "node ./scripts/check-legacy-request-extract-retirement.js",
    "check:member-request-refactor": "node ./scripts/check-member-request-refactor.js",
    "check:support-html-refactor": "node ./scripts/check-support-html-refactor.js",
    "check:refactor": "npm run check:admin-refactor && npm run check:member-request-refactor && npm run check:common-query-refactor && npm run check:legacy-phpexcel-retirement && npm run check:legacy-request-extract-retirement && npm run check:support-html-refactor"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whitedot/gnuboard5.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/whitedot/gnuboard5/issues"
  },
  "homepage": "https://github.com/whitedot/gnuboard5#readme",
  "dependencies": {
    "@tailwindcss/cli": "4.2.4",
    "@tailwindcss/typography": "0.5.19",
    "tailwindcss": "4.2.4"
  }
}
